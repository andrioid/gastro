---
type Props struct {
    Title string
}

props := gastro.Props[Props]()
Title := props.Title
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ .Title }}</title>
    <link rel="stylesheet" href="/static/styles.css">
    <script type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@v1/bundles/datastar.js"></script>
</head>
<body>
    <main>
        <slot />
    </main>
</body>
</html>
