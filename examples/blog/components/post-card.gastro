---
import Badge "components/badge.gastro"

type Props struct {
    Slug   string
    Title  string
    Author string
    Date   string
}

Slug := gastro.Props().Slug
Title := gastro.Props().Title
Author := gastro.Props().Author
Date := gastro.Props().Date
---
<article class="post-card">
    <h2><a href="/blog/{{ .Slug }}">{{ .Title }}</a></h2>
    <p class="meta">{{ Badge (dict "Label" .Author) }} on {{ .Date }}</p>
</article>
