---
import (
    "fmt"
    "dashboard/mock"
)

type Props struct {
    Agent mock.Agent
    Y int
}

p := gastro.Props()
Agent := p.Agent
Transform := fmt.Sprintf("translate(0, %d)", p.Y)
StatusText := "Ready"
switch Agent.Status {
    case mock.StatusOnCall:
        StatusText = Agent.CallDur
    case mock.StatusAway:
        StatusText = "Away"
}

---
<g class="agent-row" transform="{{ .Transform }}">
    <defs>
        <linearGradient id="rowOpacity" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="white" stop-opacity="1" />
            <stop offset="100%" stop-color="white" stop-opacity="0.8" />
        </linearGradient>
        <mask id="rowMask" maskContentUnits="objectBoundingBox">
            <rect width="1" height="1" fill="url(#rowOpacity)" />
        </mask>
    </defs>
    <g mask="url(#rowMask)">
        <rect x="30" width="1140" height="44" rx="6" fill="white" stroke="var(--color-border)" />
        <text x="50" y="28" fill="#1e293b" font-size="14" font-weight="500">{{ .Agent.Name }}</text>
        <rect class="status-badge" x="490" width="80" height="44" fill="var(--color-{{ .Agent.Status }})" />
        <text x="530" y="27" fill="white" font-size="11" font-weight="600" text-anchor="middle">{{ .StatusText }}</text>
        <text x="1140" y="28" fill="#64748b" font-size="13" font-weight="500" text-anchor="end">{{ .Agent.CallDur }}</text>
    </g>
</g>
