---
// LogoSvg renders the Gastro mark as an inline SVG.
//
// External control via classes on the root <svg>:
//   - Sizing       size-8, max-h-8, w-12 h-12, …
//   - Stroke color text-white, text-accent, …  (via currentColor inheritance)
//                  stroke-red-500, stroke-current, …  (direct stroke override)
//   - Stroke width stroke-2, stroke-[3px], …
//
// Props:
//   Class — CSS classes applied to the root <svg>.
//   Style — Inline style on the root <svg>. Useful for one-off
//           CSS-variable overrides like "--logo-stroke-width: 3"
//           without authoring a class.
//
// Defaults are SVG presentation attributes (stroke, stroke-width,
// fill, stroke-linecap, stroke-linejoin) — these have lower CSS
// priority than any class, so utility classes always win. No
// embedded <style> block because Tailwind v4 puts utilities inside
// @layer, and a layerless <style> would beat every layered class
// regardless of specificity. For a styled <img> / favicon variant
// see static/logo2.svg.
type Props struct {
	Class string
	Style string
}

p := gastro.Props()
Class := p.Class
Style := p.Style
---
<svg
	width="24"
	height="24"
	viewBox="0 0 105.83333 105.83333"
	version="1.1"
	xmlns="http://www.w3.org/2000/svg"
	fill="none"
	stroke="currentColor"
	stroke-width="2.19824"
	stroke-linecap="round"
	stroke-linejoin="round"
	{{- with .Class }} class="{{ . }}"{{ end }}
	{{- with .Style }} style="{{ . }}"{{ end }}>
	<!-- Outer silhouette -->
	<path d="M 59.513071,0.5749702 C 53.89442,0.8239672 47.691166,2.0472961 43.057672,3.822747 c -5.434611,2.0785761 -9.472679,4.6118418 -12.936974,8.086961 -2.024447,2.035274 -3.52925,4.146328 -4.492757,6.311512 -0.368081,0.82277 -0.389733,0.844422 -1.244981,0.952681 -0.876899,0.108259 -2.847217,0.649556 -3.95146,1.082592 -5.726912,2.240965 -10.317102,6.495549 -12.9478014,12.016771 -3.1286911,6.582157 -3.550901,14.08453 -1.2016767,21.002283 1.9378392,5.66196 5.6619561,10.252146 10.5769231,13.034402 0.963508,0.552128 2.836392,1.364069 3.52925,1.53729 0.433038,0.108257 0.552122,0.205695 0.887726,0.72534 0.205693,0.335596 0.617077,1.093418 0.898551,1.688837 1.244981,2.619872 1.699669,5.564522 1.580585,10.187191 -0.108259,3.778255 -0.378908,6.473901 -1.320763,13.045228 -0.725336,5.099014 -0.671206,5.889305 0.476341,7.047685 2.36005,2.34922 10.760965,4.03806 23.124165,4.64431 3.128692,0.16239 12.417334,0.16239 15.643459,0 7.924573,-0.3789 14.095342,-1.24497 18.046809,-2.54409 3.096217,-1.01764 4.514404,-2.1327 4.89331,-3.864852 0.140749,-0.606255 0.292306,-2.132709 0.498,-4.79589 0.68203,-8.888067 1.190847,-13.489081 1.851231,-16.671908 0.465508,-2.251792 0.324779,-2.013615 1.461498,-2.370876 1.959497,-0.617074 4.059714,-1.807921 5.900118,-3.334375 3.323561,-2.771447 5.716085,-7.275023 6.506375,-12.26578 0.25983,-1.656365 0.25983,-5.12065 -0.0109,-6.549675 -0.5413,-2.955477 -1.937838,-5.542866 -4.1788,-7.794659 -4.243763,-4.243763 -10.609398,-6.224905 -20.027948,-6.214078 -8.36844,0.01089 -12.904494,1.537281 -14.614989,4.925793 -1.504803,2.955477 -0.530469,7.15593 2.100229,9.028816 0.324775,0.238168 0.595427,0.465508 0.606246,0.49799 0.01086,0.140739 -2.652344,0.357252 -4.276236,0.346424 -4.633492,-0.0216 -7.924571,-1.299103 -9.927367,-3.821537 -1.937842,-2.457496 -2.186838,-6.094994 -0.617079,-9.093781 1.439849,-2.749783 4.157154,-4.590187 8.000358,-5.434611 0.995979,-0.216512 1.439845,-0.238167 3.626678,-0.238167 2.262617,0 2.695656,0.03249 4.763407,0.346424 6.841975,1.050118 10.468664,1.006817 14.214428,-0.194867 3.550905,-1.136719 6.495555,-3.540069 8.325131,-6.777022 1.472325,-2.59822 2.197665,-5.726915 2.056926,-8.855605 C 90.540132,12.212834 86.231414,6.6374856 78.512529,3.4979688 73.153702,1.3111327 66.344201,0.271845 59.513044,0.5749702 Z" />
	<!-- Bottom mouth detail -->
	<path d="M 58.322219,93.818623 c 10.555278,0.487172 18.447372,1.840404 22.420485,3.843192 0.671202,0.346433 1.396551,0.99599 1.396551,1.244985 0,1.08259 -3.540088,2.41418 -8.801486,3.3019 -4.817527,0.81195 -10.057277,1.20169 -17.343119,1.30995 -13.445795,0.20569 -25.982211,-1.21251 -30.377534,-3.43183 -1.385719,-0.69286 -1.623889,-1.212493 -0.876901,-1.937842 2.262618,-2.143527 10.609401,-3.832365 21.456975,-4.319528 2.803914,-0.129911 9.461851,-0.129911 12.125029,-0.01089 z" />
</svg>
