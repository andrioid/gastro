{
  "name": "gastro-vscode",
  "displayName": "Gastro",
  "description": "Language support for Gastro (.gastro) files - syntax highlighting, LSP, and completions",
  "version": "1.0.1",
  "publisher": "andrioid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrioid/gastro",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/andrioid/gastro",
  "bugs": {
    "url": "https://github.com/andrioid/gastro/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onLanguage:gastro"
  ],
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "gastro",
    "go",
    "template",
    "component",
    "language-server"
  ],
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "contributes": {
    "languages": [
      {
        "id": "gastro",
        "aliases": [
          "Gastro"
        ],
        "extensions": [
          ".gastro"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gastro",
        "scopeName": "source.gastro",
        "path": "./syntaxes/gastro.tmLanguage.json",
        "embeddedLanguages": {
          "source.go": "go",
          "text.html.basic": "html"
        }
      }
    ]
  },
  "main": "./extension.js"
}
