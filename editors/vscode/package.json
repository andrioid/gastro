{
  "name": "gastro-vscode",
  "displayName": "Gastro",
  "description": "Language support for Gastro (.gastro) files - syntax highlighting, LSP, and completions",
  "version": "0.1.14",
  "publisher": "andrioid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrioid/gastro",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/andrioid/gastro",
  "bugs": {
    "url": "https://github.com/andrioid/gastro/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onLanguage:gastro"
  ],
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "gastro",
    "go",
    "template",
    "component",
    "language-server"
  ],
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  },
  "contributes": {
    "configuration": {
      "title": "Gastro",
      "properties": {
        "gastro.lspPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the gastro binary. Leave empty to find it on PATH."
        },
        "gastro-lsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the Gastro Language Server."
        }
      }
    },
    "languages": [
      {
        "id": "gastro",
        "aliases": [
          "Gastro"
        ],
        "extensions": [
          ".gastro"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gastro",
        "scopeName": "source.gastro",
        "path": "./syntaxes/gastro.tmLanguage.json",
        "embeddedLanguages": {
          "source.go": "go",
          "text.html.basic": "html"
        }
      }
    ]
  },
  "main": "./dist/extension.js"
}
