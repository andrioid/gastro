#!/usr/bin/env bash
#MISE description="Symlink the VS Code extension for local development"
#MISE depends=["build:vscode-deps"]

set -euo pipefail

EXTENSION_DIR="$HOME/.vscode/extensions"
VERSION=$(node -p "require('./editors/vscode/package.json').version")
LINK_NAME="andrioid.gastro-vscode-${VERSION}"
TARGET="$PWD/editors/vscode"

if [ -L "$EXTENSION_DIR/$LINK_NAME" ]; then
  echo "Symlink already exists: $EXTENSION_DIR/$LINK_NAME"
else
  ln -sfn "$TARGET" "$EXTENSION_DIR/$LINK_NAME"
  echo "Linked $TARGET -> $EXTENSION_DIR/$LINK_NAME"
fi

echo "Restart VS Code to pick up changes."
