#!/usr/bin/env bash
#MISE description="Build gastro-lsp and bundle into the VS Code extension"
#MISE depends=["build:vscode-deps"]

set -euo pipefail

VERSION="${GASTRO_VERSION:-dev}"

go build -ldflags "-X main.version=${VERSION}" -o editors/vscode/bin/gastro-lsp ./cmd/gastro-lsp/
echo "Built editors/vscode/bin/gastro-lsp (${VERSION})"
