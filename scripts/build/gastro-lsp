#!/usr/bin/env bash
#MISE description="Build the gastro-lsp binary"
#MISE sources=["cmd/gastro-lsp/**/*.go", "internal/**/*.go", "pkg/**/*.go"]
#MISE outputs=["bin/gastro-lsp"]

set -euo pipefail

VERSION="${GASTRO_VERSION:-dev}"

mkdir -p bin
go build -ldflags "-X main.version=${VERSION}" -o bin/gastro-lsp ./cmd/gastro-lsp/
echo "Built bin/gastro-lsp (${VERSION})"
